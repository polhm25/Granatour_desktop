# Ejemplo de configuración para diferentes entornos
# Copia este archivo a .env y actualiza los valores según tu entorno

# ============================================
# CONFIGURACIÓN DE DOCKER LAMP STACK
# ============================================

# Puerto MySQL en Docker
MYSQL_PORT=3307

# Base de datos
MYSQL_DATABASE=grana_tour
MYSQL_ROOT_PASSWORD=root_password
MYSQL_USER=grana_user
MYSQL_PASSWORD=grana_password

# Apache/PHP
APACHE_PORT=80
APACHE_SSL_PORT=443

# phpMyAdmin
PHPMYADMIN_PORT=8080

# ============================================
# CONFIGURACIÓN PARA DESARROLLO LOCAL
# ============================================
# Si usas una instancia de MySQL local en lugar de Docker:
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=grana_tour
# DB_USER=root
# DB_PASSWORD=root_password
