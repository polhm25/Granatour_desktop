<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controllers.ExcursionesController">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
   <children>

      <!-- TOOLBAR: Título + Búsqueda -->
      <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="view-toolbar">
         <children>
            <FontIcon iconLiteral="mdi-nature" iconSize="22" iconColor="#4CAF50" />
            <Label text="Gestión de Excursiones" styleClass="section-title" />
            <Label fx:id="recordCountLabel" styleClass="record-count" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" prefWidth="280.0" promptText="Buscar por nombre de ruta o zona...">
               <HBox.margin><Insets /></HBox.margin>
            </TextField>
            <Button fx:id="buscarButton" mnemonicParsing="true" styleClass="button-primary" text="🔍 _Buscar">
               <tooltip><Tooltip text="Buscar excursiones (Alt+B)" /></tooltip>
            </Button>
         </children>
      </HBox>

      <!-- TABLE VIEW -->
      <TableView fx:id="excursionesTable" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="nombreRutaColumn" prefWidth="130.0" text="Nombre Ruta" />
          <TableColumn fx:id="zonaColumn" prefWidth="110.0" text="Zona" />
          <TableColumn fx:id="duracionColumn" prefWidth="85.0" text="Duración (h)" />
          <TableColumn fx:id="precioColumn" prefWidth="85.0" text="Precio (€)" />
          <TableColumn fx:id="fechaColumn" prefWidth="105.0" text="Fecha Inicio" />
          <TableColumn fx:id="plazasColumn" prefWidth="80.0" text="Plazas" />
          <TableColumn fx:id="guiaColumn" prefWidth="160.0" text="Guía Asignado" />
        </columns>
      </TableView>

      <!-- ACTION BUTTONS -->
      <HBox alignment="CENTER" spacing="10.0">
         <padding>
            <Insets top="12.0" />
         </padding>
         <children>
            <Button fx:id="añadirButton" mnemonicParsing="true" styleClass="button-primary" text="➕ _Añadir">
               <tooltip><Tooltip text="Añadir nueva excursión (Alt+A)" /></tooltip>
            </Button>
            <Button fx:id="editarButton" mnemonicParsing="true" styleClass="button-info" text="✏ _Editar">
               <tooltip><Tooltip text="Editar excursión seleccionada (Alt+E)" /></tooltip>
            </Button>
            <Button fx:id="eliminarButton" mnemonicParsing="true" styleClass="button-danger" text="🗑 E_liminar">
               <tooltip><Tooltip text="Eliminar excursión seleccionada (Alt+L)" /></tooltip>
            </Button>
            <Button fx:id="generarInformeButton" mnemonicParsing="true" styleClass="button-cancel" text="📄 Generar _Catálogo">
               <tooltip><Tooltip text="Generar catálogo de excursiones en HTML (Alt+C)" /></tooltip>
            </Button>
            <Button fx:id="estadisticasButton" mnemonicParsing="true" styleClass="button-secondary" text="📊 Estadísticas">
               <tooltip><Tooltip text="Ver estadísticas de excursiones por zona (Alt+Z)" /></tooltip>
            </Button>
         </children>
      </HBox>

   </children>
</VBox>
