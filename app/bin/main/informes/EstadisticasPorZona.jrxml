<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="EstadisticasPorZona"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <queryString>
        <![CDATA[
            SELECT
                zona,
                COUNT(*) AS total_excursiones,
                SUM(plazas_disponibles) AS total_plazas,
                AVG(precio_persona) AS precio_promedio,
                MIN(precio_persona) AS precio_min,
                MAX(precio_persona) AS precio_max
            FROM EXCURSIONES
            GROUP BY zona
            ORDER BY zona
        ]]>
    </queryString>

    <field name="zona" class="java.lang.String"/>
    <field name="total_excursiones" class="java.lang.Long"/>
    <field name="total_plazas" class="java.lang.Long"/>
    <field name="precio_promedio" class="java.math.BigDecimal"/>
    <field name="precio_min" class="java.math.BigDecimal"/>
    <field name="precio_max" class="java.math.BigDecimal"/>

    <variable name="TOTAL_EXCURSIONES_GLOBAL" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{total_excursiones}]]></variableExpression>
    </variable>
    <variable name="TOTAL_PLAZAS_GLOBAL" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{total_plazas}]]></variableExpression>
    </variable>

    <!-- Título con encabezado verde -->
    <title>
        <band height="80">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="50" backcolor="#2E7D32" forecolor="#2E7D32"/>
            </rectangle>
            <staticText>
                <reportElement x="15" y="8" width="250" height="18" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[GRANATOUR]]></text>
            </staticText>
            <staticText>
                <reportElement x="15" y="28" width="250" height="12" forecolor="#C8E6C9"/>
                <textElement>
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <text><![CDATA[Agencia Oficial de Turismo y Senderismo]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="14" width="80" height="12" forecolor="#C8E6C9"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Fecha emisión:]]></text>
            </staticText>
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement x="465" y="14" width="80" height="12" forecolor="#FFFFFF"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="55" width="555" height="1" forecolor="#4CAF50"/>
            </line>
            <staticText>
                <reportElement x="0" y="60" width="555" height="18" forecolor="#2E7D32"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[ESTADÍSTICAS DE EXCURSIONES POR ZONA]]></text>
            </staticText>
        </band>
    </title>

    <!-- Cabeceras de columnas con fondo verde -->
    <columnHeader>
        <band height="28">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="28" backcolor="#2E7D32" forecolor="#2E7D32"/>
            </rectangle>
            <staticText>
                <reportElement x="5" y="0" width="110" height="28" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[ZONA]]></text>
            </staticText>
            <staticText>
                <reportElement x="120" y="0" width="80" height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[EXCURSIONES]]></text>
            </staticText>
            <staticText>
                <reportElement x="205" y="0" width="80" height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[PLAZAS TOTALES]]></text>
            </staticText>
            <staticText>
                <reportElement x="290" y="0" width="90" height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[PRECIO PROM.]]></text>
            </staticText>
            <staticText>
                <reportElement x="385" y="0" width="80" height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[PRECIO MÍN.]]></text>
            </staticText>
            <staticText>
                <reportElement x="470" y="0" width="80" height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[PRECIO MÁX.]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- Detalle con filas alternas -->
    <detail>
        <band height="24">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="23" backcolor="#F1F8E9" forecolor="#E0E0E0">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
            </rectangle>
            <line>
                <reportElement x="0" y="23" width="555" height="1" forecolor="#E0E0E0"/>
            </line>
            <textField isBlankWhenNull="true">
                <reportElement x="5" y="2" width="110" height="20" forecolor="#212121"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{zona}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="120" y="2" width="80" height="20" forecolor="#2E7D32"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{total_excursiones}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="205" y="2" width="80" height="20" forecolor="#424242"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{total_plazas}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00 €" isBlankWhenNull="true">
                <reportElement x="290" y="2" width="90" height="20" forecolor="#424242"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{precio_promedio}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00 €" isBlankWhenNull="true">
                <reportElement x="385" y="2" width="80" height="20" forecolor="#424242"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{precio_min}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00 €" isBlankWhenNull="true">
                <reportElement x="470" y="2" width="80" height="20" forecolor="#424242"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{precio_max}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- Resumen con totales -->
    <summary>
        <band height="80">
            <line>
                <reportElement x="0" y="10" width="555" height="1" forecolor="#4CAF50"/>
            </line>
            <staticText>
                <reportElement x="0" y="18" width="555" height="18" forecolor="#2E7D32"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTALES GENERALES]]></text>
            </staticText>
            <rectangle>
                <reportElement x="80" y="40" width="395" height="30" forecolor="#C8E6C9" backcolor="#E8F5E9"/>
            </rectangle>
            <staticText>
                <reportElement x="90" y="40" width="150" height="30" forecolor="#424242"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <text><![CDATA[Total de excursiones en catálogo:]]></text>
            </staticText>
            <textField>
                <reportElement x="250" y="40" width="60" height="30" forecolor="#2E7D32"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_EXCURSIONES_GLOBAL}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="320" y="40" width="100" height="30" forecolor="#424242"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <text><![CDATA[Total plazas disponibles:]]></text>
            </staticText>
            <textField>
                <reportElement x="425" y="40" width="40" height="30" forecolor="#2E7D32"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_PLAZAS_GLOBAL}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
