<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controllers.ReportesController">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
   <children>

      <!-- TOOLBAR: Título + Botón actualizar -->
      <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="view-toolbar">
         <children>
            <FontIcon iconLiteral="mdi-chart-bar" iconSize="22" iconColor="#4CAF50" />
            <Label text="Informes y Estadísticas" styleClass="section-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="actualizarButton" styleClass="button-primary" text="🔄 Actualizar">
               <tooltip><Tooltip text="Actualizar gráficas" /></tooltip>
            </Button>
         </children>
      </HBox>

      <!-- FILA DE GRÁFICAS -->
      <HBox spacing="15.0" VBox.vgrow="ALWAYS">
         <padding>
            <Insets top="12.0" />
         </padding>
         <children>

            <!-- BarChart horizontal: Excursiones por Zona -->
            <BarChart fx:id="excursionesPorZonaChart" title="Excursiones por Zona"
                      legendVisible="false" HBox.hgrow="ALWAYS">
               <xAxis>
                  <NumberAxis label="Número de Excursiones" />
               </xAxis>
               <yAxis>
                  <CategoryAxis label="Zona" />
               </yAxis>
            </BarChart>

            <!-- PieChart: Reservas por Estado -->
            <PieChart fx:id="reservasPorEstadoChart" title="Reservas por Estado"
                      legendVisible="true" HBox.hgrow="ALWAYS" />

         </children>
      </HBox>

      <!-- FRANJA INFERIOR: Generar informe PDF -->
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <padding>
            <Insets top="12.0" />
         </padding>
         <children>
            <Label text="Estado del informe:" style="-fx-text-fill: -text-secondary; -fx-font-size: 13px;" />
            <ComboBox fx:id="estadoInformeComboBox" prefWidth="130.0" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="generarInformeButton" styleClass="button-cancel" text="📄 Generar Informe PDF">
               <tooltip><Tooltip text="Generar informe PDF de reservas por estado" /></tooltip>
            </Button>
         </children>
      </HBox>

   </children>
</VBox>
