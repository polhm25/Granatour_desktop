<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.Tooltip?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="1000.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controllers.MainController">

   <!-- HEADER: Logo + User info + Logout -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="header">
         <padding>
            <Insets bottom="12.0" left="20.0" right="20.0" top="12.0" />
         </padding>
         <children>
            <Label text="GranaTour" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="userInfoLabel" textFill="WHITE" style="-fx-font-size: 12px;" />
            <Button fx:id="cerrarSesionButton" mnemonicParsing="true"
                    styleClass="button-danger"
                    text="Cerrar _Sesión"
                    style="-fx-font-size: 12px; -fx-padding: 7 14 7 14;">
               <tooltip><Tooltip text="Cerrar sesión y volver al login (Alt+S)" /></tooltip>
            </Button>
         </children>
      </HBox>
   </top>

   <!-- SIDEBAR: Navegación lateral -->
   <left>
      <VBox styleClass="sidebar" BorderPane.alignment="TOP_CENTER">
         <children>
            <Button fx:id="navUsuariosButton" styleClass="sidebar-button"
                    text="Usuarios" mnemonicParsing="false" contentDisplay="TOP" graphicTextGap="6">
               <graphic><FontIcon iconLiteral="mdi-account" iconSize="26" /></graphic>
               <tooltip><Tooltip text="Gestión de Usuarios (Alt+1)" /></tooltip>
            </Button>
            <Button fx:id="navExcursionesButton" styleClass="sidebar-button"
                    text="Excursiones" mnemonicParsing="false" contentDisplay="TOP" graphicTextGap="6">
               <graphic><FontIcon iconLiteral="mdi-nature" iconSize="26" /></graphic>
               <tooltip><Tooltip text="Gestión de Excursiones (Alt+2)" /></tooltip>
            </Button>
            <Button fx:id="navReservasButton" styleClass="sidebar-button"
                    text="Reservas" mnemonicParsing="false" contentDisplay="TOP" graphicTextGap="6">
               <graphic><FontIcon iconLiteral="mdi-calendar-check" iconSize="26" /></graphic>
               <tooltip><Tooltip text="Gestión de Reservas (Alt+3)" /></tooltip>
            </Button>
            <Button fx:id="navReportesButton" styleClass="sidebar-button"
                    text="Reportes" mnemonicParsing="false" contentDisplay="TOP" graphicTextGap="6">
               <graphic><FontIcon iconLiteral="mdi-chart-bar" iconSize="26" /></graphic>
               <tooltip><Tooltip text="Informes y Estadísticas (Alt+5)" /></tooltip>
            </Button>
            <Button fx:id="navAyudaButton" styleClass="sidebar-button"
                    text="Ayuda" mnemonicParsing="false" contentDisplay="TOP" graphicTextGap="6">
               <graphic><FontIcon iconLiteral="mdi-help-circle" iconSize="26" /></graphic>
               <tooltip><Tooltip text="Centro de Ayuda (Alt+4)" /></tooltip>
            </Button>
         </children>
      </VBox>
   </left>

   <!-- CENTER: StackPane para contenido de las vistas -->
   <center>
      <StackPane fx:id="contentArea" style="-fx-background-color: -background;" BorderPane.alignment="CENTER" />
   </center>

</BorderPane>
