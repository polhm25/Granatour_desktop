<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.Tooltip?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controllers.MainController">
   <top>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <!-- ROW 1: Logo + Title -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="header">
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
               <children>
                  <Label text=" GranaTour" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            
            <!-- ROW 2: Icon Navigation + User Info -->
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="navbar">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
               <children>
                  <Button fx:id="iconUsuariosButton" mnemonicParsing="false" prefHeight="50.0" prefWidth="70.0" styleClass="icon-button">
                     <graphic>
                        <FontIcon iconLiteral="mdi-account" iconSize="28" />
                     </graphic>
                     <tooltip><Tooltip text="Gestión de Usuarios (Alt+1)" /></tooltip>
                  </Button>
                  <Button fx:id="iconExcursionesButton" mnemonicParsing="false" prefHeight="51.0" prefWidth="70.0" styleClass="icon-button">
                     <graphic>
                        <FontIcon iconLiteral="mdi-nature" iconSize="28" />
                     </graphic>
                     <tooltip><Tooltip text="Gestión de Excursiones (Alt+2)" /></tooltip>
                  </Button>
                  <Button fx:id="iconReservasButton" mnemonicParsing="false" prefHeight="50.0" prefWidth="70.0" styleClass="icon-button">
                     <graphic>
                        <FontIcon iconLiteral="mdi-calendar-check" iconSize="28" />
                     </graphic>
                     <tooltip><Tooltip text="Gestión de Reservas (Alt+3)" /></tooltip>
                  </Button>
                  <Button fx:id="iconAyudaButton" mnemonicParsing="false" prefHeight="50.0" prefWidth="70.0" styleClass="icon-button">
                     <graphic>
                        <FontIcon iconLiteral="mdi-help-circle" iconSize="28" />
                     </graphic>
                     <tooltip><Tooltip text="Centro de Ayuda (Alt+4)" /></tooltip>
                  </Button>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="userInfoLabel" text="Usuario: Pablo Hernández Martínez | Rol: admin">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Label>
                  <Button fx:id="cerrarSesionButton" mnemonicParsing="true" style="-fx-background-color: #F44336; -fx-text-fill: white;" text="Cerrar _Sesión">
                     <tooltip><Tooltip text="Cerrar sesión y volver al login (Alt+S)" /></tooltip>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <!-- CENTER: TabPane with text tabs -->
   <center>
      <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
        <tabs>
          <Tab fx:id="tabUsuarios" text="USUARIOS" />
          <Tab fx:id="tabExcursiones" text="EXCURSIONES" />
          <Tab fx:id="tabReservas" text="RESERVAS" />
          <Tab fx:id="tabAyuda" text="AYUDA" />
        </tabs>
      </TabPane>
   </center>
</BorderPane>
