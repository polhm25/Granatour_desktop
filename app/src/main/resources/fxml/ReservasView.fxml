<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controllers.ReservasController">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
   <children>

      <!-- TOOLBAR: Título + Búsqueda -->
      <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="view-toolbar">
         <children>
            <FontIcon iconLiteral="mdi-calendar-check" iconSize="22" iconColor="#4CAF50" />
            <Label text="Gestión de Reservas" styleClass="section-title" />
            <Label fx:id="recordCountLabel" styleClass="record-count" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" prefWidth="280.0" promptText="Buscar por cliente, excursión o estado...">
               <HBox.margin><Insets /></HBox.margin>
            </TextField>
            <Button fx:id="buscarButton" mnemonicParsing="true" styleClass="button-primary" text="🔍 _Buscar">
               <tooltip><Tooltip text="Buscar reservas (Alt+B)" /></tooltip>
            </Button>
         </children>
      </HBox>

      <!-- TABLE VIEW -->
      <TableView fx:id="reservasTable" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="clienteColumn" prefWidth="160.0" text="Cliente" />
          <TableColumn fx:id="excursionColumn" prefWidth="155.0" text="Excursión" />
          <TableColumn fx:id="fechaColumn" prefWidth="150.0" text="Fecha Reserva" />
          <TableColumn fx:id="personasColumn" prefWidth="80.0" text="Personas" />
          <TableColumn fx:id="estadoColumn" prefWidth="115.0" text="Estado" />
          <TableColumn fx:id="precioColumn" prefWidth="110.0" text="Precio Total (€)" />
        </columns>
      </TableView>

      <!-- ACTION BUTTONS -->
      <HBox alignment="CENTER" spacing="10.0">
         <padding>
            <Insets top="12.0" />
         </padding>
         <children>
            <!-- Acciones CRUD -->
            <Button fx:id="añadirButton" mnemonicParsing="true" styleClass="button-primary" text="➕ _Añadir">
               <tooltip><Tooltip text="Añadir nueva reserva (Alt+A)" /></tooltip>
            </Button>
            <Button fx:id="editarButton" mnemonicParsing="true" styleClass="button-info" text="✏ _Editar">
               <tooltip><Tooltip text="Editar reserva seleccionada (Alt+E)" /></tooltip>
            </Button>
            <Button fx:id="eliminarButton" mnemonicParsing="true" styleClass="button-danger" text="🗑 E_liminar">
               <tooltip><Tooltip text="Eliminar reserva seleccionada (Alt+L)" /></tooltip>
            </Button>
         </children>
      </HBox>

   </children>
</VBox>
