<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controllers.ReservasController">
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
   <children>
      <!-- SEARCH AREA -->
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <TextField fx:id="searchField" prefWidth="300.0" promptText="Buscar por cliente, excursión o estado..." />
            <Button fx:id="buscarButton" mnemonicParsing="false" text="🔍 Buscar" />
         </children>
      </HBox>

      <!-- TABLE VIEW -->
      <TableView fx:id="reservasTable" prefHeight="400.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="clienteColumn" prefWidth="150.0" text="Cliente" />
          <TableColumn fx:id="excursionColumn" prefWidth="150.0" text="Excursión" />
          <TableColumn fx:id="fechaColumn" prefWidth="150.0" text="Fecha Reserva" />
          <TableColumn fx:id="personasColumn" prefWidth="80.0" text="Personas" />
          <TableColumn fx:id="estadoColumn" prefWidth="100.0" text="Estado" />
          <TableColumn fx:id="precioColumn" prefWidth="100.0" text="Precio Total (€)" />
        </columns>
      </TableView>

      <!-- REPORT GENERATION SECTION -->
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <padding>
            <Insets top="5.0" />
         </padding>
         <children>
            <Label text="Estado del informe:" />
            <ComboBox fx:id="estadoInformeComboBox" prefWidth="120.0" />
            <Button fx:id="generarInformeButton" mnemonicParsing="false" style="-fx-background-color: #757575; -fx-text-fill: white;" text="Generar Informe PDF" />
         </children>
      </HBox>

      <!-- ACTION BUTTONS -->
      <HBox alignment="CENTER" spacing="10.0">
         <padding>
            <Insets top="10.0" />
         </padding>
         <children>
            <Button fx:id="añadirButton" mnemonicParsing="false" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="➕ Añadir" />
            <Button fx:id="editarButton" mnemonicParsing="false" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="✏ Editar" />
            <Button fx:id="eliminarButton" mnemonicParsing="false" style="-fx-background-color: #F44336; -fx-text-fill: white;" text="🗑 Eliminar" />
            <Button fx:id="actualizarButton" mnemonicParsing="false" text="🔄 Actualizar" />
         </children>
      </HBox>
   </children>
</VBox>
