<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controllers.UsuariosController">
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
   <children>
      <!-- SEARCH AREA -->
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <TextField fx:id="searchField" prefWidth="300.0" promptText="Buscar por DNI, nombre, email..." />
            <Button fx:id="buscarButton" mnemonicParsing="true" text="🔍 _Buscar">
               <tooltip><Tooltip text="Buscar usuarios por nombre, email o DNI (Alt+B)" /></tooltip>
            </Button>
         </children>
      </HBox>
      
      <!-- TABLE VIEW -->
      <TableView fx:id="usuariosTable" prefHeight="400.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="dniColumn" prefWidth="100.0" text="DNI" />
          <TableColumn fx:id="nombreColumn" prefWidth="120.0" text="Nombre" />
            <TableColumn fx:id="apellidosColumn" prefWidth="180.0" text="Apellidos" />
            <TableColumn fx:id="emailColumn" prefWidth="200.0" text="Email" />
            <TableColumn fx:id="telefonoColumn" prefWidth="120.0" text="Teléfono" />
            <TableColumn fx:id="rolColumn" prefWidth="100.0" text="Rol" />
        </columns>
      </TableView>
      
      <!-- ACTION BUTTONS -->
      <HBox alignment="CENTER" spacing="10.0">
         <padding>
            <Insets top="10.0" />
         </padding>
         <children>
            <Button fx:id="añadirButton" mnemonicParsing="true" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="➕ _Añadir">
               <tooltip><Tooltip text="Añadir nuevo usuario (Alt+A)" /></tooltip>
            </Button>
            <Button fx:id="editarButton" mnemonicParsing="true" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="✏ _Editar">
               <tooltip><Tooltip text="Editar usuario seleccionado (Alt+E)" /></tooltip>
            </Button>
            <Button fx:id="eliminarButton" mnemonicParsing="true" style="-fx-background-color: #F44336; -fx-text-fill: white;" text="🗑 E_liminar">
               <tooltip><Tooltip text="Eliminar usuario seleccionado (Alt+L)" /></tooltip>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>
