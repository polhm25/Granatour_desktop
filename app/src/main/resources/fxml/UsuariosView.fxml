<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controllers.UsuariosController">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
   <children>

      <!-- TOOLBAR: Título + Búsqueda -->
      <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="view-toolbar">
         <children>
            <FontIcon iconLiteral="mdi-account" iconSize="22" iconColor="#4CAF50" />
            <Label text="Gestión de Usuarios" styleClass="section-title" />
            <Label fx:id="recordCountLabel" styleClass="record-count" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" prefWidth="280.0" promptText="Buscar por DNI, nombre, email...">
               <HBox.margin><Insets /></HBox.margin>
            </TextField>
            <Button fx:id="buscarButton" mnemonicParsing="true" styleClass="button-primary" text="🔍 _Buscar">
               <tooltip><Tooltip text="Buscar usuarios (Alt+B)" /></tooltip>
            </Button>
         </children>
      </HBox>

      <!-- TABLE VIEW -->
      <TableView fx:id="usuariosTable" VBox.vgrow="ALWAYS" style="-fx-border-radius: 0 0 8 8;">
        <columns>
          <TableColumn fx:id="dniColumn" prefWidth="100.0" text="DNI" />
          <TableColumn fx:id="nombreColumn" prefWidth="120.0" text="Nombre" />
          <TableColumn fx:id="apellidosColumn" prefWidth="180.0" text="Apellidos" />
          <TableColumn fx:id="emailColumn" prefWidth="200.0" text="Email" />
          <TableColumn fx:id="telefonoColumn" prefWidth="120.0" text="Teléfono" />
          <TableColumn fx:id="rolColumn" prefWidth="100.0" text="Rol" />
        </columns>
        <VBox.margin><Insets top="0" /></VBox.margin>
      </TableView>

      <!-- ACTION BUTTONS -->
      <HBox alignment="CENTER" spacing="10.0">
         <padding>
            <Insets top="12.0" />
         </padding>
         <children>
            <Button fx:id="añadirButton" mnemonicParsing="true" styleClass="button-primary" text="➕ _Añadir">
               <tooltip><Tooltip text="Añadir nuevo usuario (Alt+A)" /></tooltip>
            </Button>
            <Button fx:id="editarButton" mnemonicParsing="true" styleClass="button-info" text="✏ _Editar">
               <tooltip><Tooltip text="Editar usuario seleccionado (Alt+E)" /></tooltip>
            </Button>
            <Button fx:id="eliminarButton" mnemonicParsing="true" styleClass="button-danger" text="🗑 E_liminar">
               <tooltip><Tooltip text="Eliminar usuario seleccionado (Alt+L)" /></tooltip>
            </Button>
         </children>
      </HBox>

   </children>
</VBox>
