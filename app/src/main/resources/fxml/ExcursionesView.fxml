<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controllers.ExcursionesController">
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
   <children>
      <!-- SEARCH AREA -->
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <TextField fx:id="searchField" prefWidth="300.0" promptText="Buscar por nombre de ruta o zona..." />
            <Button fx:id="buscarButton" mnemonicParsing="true" text="🔍 _Buscar">
               <tooltip><Tooltip text="Buscar excursiones por nombre o zona (Alt+B)" /></tooltip>
            </Button>
         </children>
      </HBox>

      <!-- TABLE VIEW -->
      <TableView fx:id="excursionesTable" prefHeight="400.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="nombreRutaColumn" prefWidth="120.0" text="Nombre Ruta" />
          <TableColumn fx:id="zonaColumn" prefWidth="100.0" text="Zona" />
          <TableColumn fx:id="duracionColumn" prefWidth="80.0" text="Duración (h)" />
          <TableColumn fx:id="precioColumn" prefWidth="80.0" text="Precio (€)" />
          <TableColumn fx:id="fechaColumn" prefWidth="100.0" text="Fecha Inicio" />
          <TableColumn fx:id="plazasColumn" prefWidth="80.0" text="Plazas" />
          <TableColumn fx:id="guiaColumn" prefWidth="150.0" text="Guía Asignado" />
        </columns>
      </TableView>

      <!-- ACTION BUTTONS -->
      <HBox alignment="CENTER" spacing="10.0">
         <padding>
            <Insets top="10.0" />
         </padding>
         <children>
            <Button fx:id="añadirButton" mnemonicParsing="true" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="➕ _Añadir">
               <tooltip><Tooltip text="Añadir nueva excursión (Alt+A)" /></tooltip>
            </Button>
            <Button fx:id="editarButton" mnemonicParsing="true" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="✏ _Editar">
               <tooltip><Tooltip text="Editar excursión seleccionada (Alt+E)" /></tooltip>
            </Button>
            <Button fx:id="eliminarButton" mnemonicParsing="true" style="-fx-background-color: #F44336; -fx-text-fill: white;" text="🗑 E_liminar">
               <tooltip><Tooltip text="Eliminar excursión seleccionada (Alt+L)" /></tooltip>
            </Button>
            <Button fx:id="generarInformeButton" mnemonicParsing="true" style="-fx-background-color: #757575; -fx-text-fill: white;" text="Generar _Catálogo">
               <tooltip><Tooltip text="Generar catálogo de excursiones en HTML (Alt+C)" /></tooltip>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>
